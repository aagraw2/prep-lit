# ============================================================================
# PrepLit Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# Docker Compose Settings
# ----------------------------------------------------------------------------
# Set to "dev" for hot reload, "prod" for production builds
COMPOSE_PROFILES=dev
APP_DEV_MODE=true

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
POSTGRES_DB=preplit
POSTGRES_USER=preplit
POSTGRES_PASSWORD=your_secure_password
POSTGRES_URL=jdbc:postgresql://postgres:5432/preplit

# ----------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ----------------------------------------------------------------------------
# AI Provider Configuration
# ----------------------------------------------------------------------------
# Supported providers: anthropic, openai, sarvam
#
# Each provider uses a different embedding model for RAG:
#   - anthropic → voyage-3 (requires VOYAGE_API_KEY)
#   - openai    → text-embedding-3-small (uses AI_API_KEY)
#   - sarvam    → nomic-embed-text (via Ollama, free/local)
# ----------------------------------------------------------------------------

# ========================
# OPTION 1: Anthropic (Claude)
# ========================
# AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-4-20250514
# AI_API_KEY=sk-ant-api03-xxxxxxxxxxxxx
# AI_BASE_URL=
# VOYAGE_API_KEY=pa-xxxxxxxxxxxxx   # Required for embeddings with Anthropic

# ========================
# OPTION 2: OpenAI (GPT)
# ========================
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# AI_API_KEY=sk-xxxxxxxxxxxxx
# AI_BASE_URL=

# ========================
# OPTION 3: Sarvam (OpenAI-compatible)
# ========================
AI_PROVIDER=sarvam
AI_MODEL=sarvam-m
AI_API_KEY=your_sarvam_api_key
AI_BASE_URL=https://api.sarvam.ai/v1

# ----------------------------------------------------------------------------
# RAG (Retrieval Augmented Generation) Configuration
# ----------------------------------------------------------------------------
# RAG uses the interview-guide submodule to provide context-aware responses
# ----------------------------------------------------------------------------

# Enable/disable RAG (default: true)
RAG_ENABLED=true

# Path to interview guide (default: interview-guide)
RAG_GUIDE_PATH=interview-guide

# Ollama base URL for local embeddings (used with sarvam provider)
# When running in Docker: http://ollama:11434
# When running locally: http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434

# Voyage AI API key (required when AI_PROVIDER=anthropic)
# Get your key at: https://www.voyageai.com/
# VOYAGE_API_KEY=pa-xxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# Provider-Specific Notes
# ----------------------------------------------------------------------------
#
# ANTHROPIC:
#   - Uses Claude models (claude-sonnet-4-20250514, claude-opus-4-5-20250514, etc.)
#   - Requires separate Voyage AI key for embeddings
#   - Get Anthropic key: https://console.anthropic.com/
#   - Get Voyage key: https://www.voyageai.com/
#
# OPENAI:
#   - Uses GPT models (gpt-4o, gpt-4-turbo, gpt-3.5-turbo, etc.)
#   - Same API key used for both chat and embeddings
#   - Get key: https://platform.openai.com/api-keys
#
# SARVAM:
#   - Indian AI provider, OpenAI-compatible API
#   - Uses Ollama for embeddings (free, runs in Docker)
#   - Get key: https://www.sarvam.ai/
#   - First run will pull nomic-embed-text model (~270MB)
#
# ----------------------------------------------------------------------------
# First-Time Setup Notes
# ----------------------------------------------------------------------------
#
# 1. Copy this file: cp .env.example .env
# 2. Choose your AI provider and fill in the required keys
# 3. Run: docker-compose up
#
# For Sarvam provider (default), first run takes ~2-3 minutes to:
#   - Start Ollama container
#   - Pull nomic-embed-text embedding model
#   - Index interview guide content
#
# Subsequent runs are instant (models and index are cached).
#
# ----------------------------------------------------------------------------
